
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>JC Tech Studio</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Mono:ital@0;1&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Syne', sans-serif; }
      @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.2; }
      }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-blink { animation: blink 2s ease-in-out infinite; }
      .fade-1 { animation: fadeUp 0.6s ease forwards; animation-delay: 0.1s; opacity: 0; }
      .fade-2 { animation: fadeUp 0.6s ease forwards; animation-delay: 0.25s; opacity: 0; }
      .fade-3 { animation: fadeUp 0.6s ease forwards; animation-delay: 0.4s; opacity: 0; }
      .fade-4 { animation: fadeUp 0.6s ease forwards; animation-delay: 0.55s; opacity: 0; }
    </style>
  </head>
  <body class="bg-zinc-950 text-zinc-100 min-h-screen overflow-x-hidden">

    <!-- Glow decoration -->
    <div class="fixed top-0 right-0 w-150 h-150 rounded-full blur-3xl pointer-events-none -translate-y-1/2 translate-x-1/2 bg-highlight-lila/5"></div>

    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-10 flex justify-between items-center px-8 py-5 border-b border-white/5 backdrop-blur-md">
      <span class="mono text-xs tracking-widest uppercase text-zinc-100 font-bold">JC Tech Studio</span>
      <div class="mono flex items-center gap-2 text-xs border border-highlight-lila rounded-full px-4 py-2 bg-highlight-lila/5 text-highlight-lila">
        <span class="w-1.5 h-1.5 rounded-full animate-blink bg-highlight-lila"></span>
        online · coolify
      </div>
    </nav>

    <!-- Main -->
    <main class="max-w-5xl mx-auto px-8 pt-36 pb-12 min-h-screen flex flex-col justify-between">
      <div class="flex flex-col gap-10 py-12">

        <!-- Eyebrow -->
        <div class="fade-1 mono flex items-center gap-4 text-xs tracking-widest uppercase text-zinc-500">
          Infraestructura propia
          <span class="h-px w-14 bg-highlight-lila"></span>
        </div>

        <!-- Heading -->
        <h1 class="fade-2 text-[clamp(3.5rem,10vw,8rem)] font-extrabold leading-[0.95] tracking-tight">
          Código.<br/>
          <span class="text-highlight-lila">Sin límites.</span>
        </h1>

        <!-- Description -->
        <p class="fade-3 mono text-sm text-zinc-500 leading-relaxed max-w-sm border-l-2 border-zinc-800 pl-5">
          Proyectos web a medida desplegados en servidor propio.
          Control total sobre cada línea de código.
        </p>

        <!-- Tags -->
        <div class="fade-4 flex flex-wrap gap-2">
          {["Astro SSR", "React", "Node.js", "Docker", "MongoDB", "Coolify"].map(tag => (
            <span class="mono text-xs px-3 py-1.5 border border-zinc-800 rounded text-zinc-500 hover:border-[#a778be] hover:text-[#a778be] transition-colors cursor-default">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <!-- Bottom metrics -->
      <div class="grid grid-cols-3 border-t border-zinc-800 divide-x divide-zinc-800 mt-16">
        {[
          { value: "4×", label: "vCPU dedicados" },
          { value: "8GB", label: "RAM disponible" },
          { value: "75GB", label: "NVMe storage" },
        ].map(({ value, label }) => (
          <div class="px-6 py-5 hover:bg-zinc-900 transition-colors">
            <div class="text-3xl font-extrabold text-zinc-100">
              {value.replace(/[×GBx]/g, '')}<span class="text-highlight-lila">{value.match(/[×GB]+/)?.[0]}</span>
            </div>
            <div class="mono text-xs text-zinc-500 tracking-widest uppercase mt-1">{label}</div>
          </div>
        ))}
      </div>
    </main>

  </body>
</html>