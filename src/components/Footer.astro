---

---

<footer class="bg-[#0B1120] border-t border-[#589fb8]/20 mt-20">
  <div class="mx-auto max-w-7xl px-4 py-12">
    <div class="grid gap-8 md:grid-cols-4">
      <!-- Logo y descripción -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <img
            src="https://res.cloudinary.com/pruebaweb/image/upload/v1764994533/web%20JCtechStudio/logoJCTechStudio-3_kwsqey.png"
            alt="JCTechStudio"
            class="h-12 w-12 rounded-md"
          />
          <span class="text-xl font-bold text-[#E6EDF3]">JCTechStudio</span>
        </div>
        <p class="text-[#E6EDF3]/70 text-sm max-w-sm mb-6">
          Desarrollo web y soluciones digitales modernas. Transformo ideas en productos digitales escalables y fáciles de mantener.
        </p>

        <!-- Redes Sociales -->
        <div class="flex gap-3">
          <a
            href="https://www.linkedin.com/in/jocelyn-castro-flores"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-lg bg-[#589fb8]/10 hover:bg-[#0077B5]/20 flex items-center justify-center transition-all duration-300 group border border-[#589fb8]/20 hover:border-[#0077B5]/50"
            aria-label="LinkedIn"
          >
            <svg
              class="w-5 h-5 text-[#8ddad2] group-hover:text-[#0077B5] transition-colors"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
              ></path>
            </svg>
          </a>

          <a
            href="https://github.com/Jocelyn212"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-lg bg-[#589fb8]/10 hover:bg-[#333]/20 flex items-center justify-center transition-all duration-300 group border border-[#589fb8]/20 hover:border-[#333]/50"
            aria-label="GitHub"
          >
            <svg
              class="w-5 h-5 text-[#8ddad2] group-hover:text-white transition-colors"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Enlaces rápidos -->
      <div>
        <h3 class="text-[#a778be] font-semibold mb-4">Enlaces</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="https://www.jctechstudio.es/#servicios"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[#E6EDF3]/70 hover:text-[#a778be] transition-colors"
            >
              Servicios
            </a>
          </li>
          <li>
            <a
              href="https://www.jctechstudio.es/#sobre-mi"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[#E6EDF3]/70 hover:text-[#a778be] transition-colors"
            >
              Sobre mí
            </a>
          </li>
          <li>
            <a
              href="https://www.jctechstudio.es/#contacto"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[#E6EDF3]/70 hover:text-[#a778be] transition-colors"
            >
              Contacto
            </a>
          </li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h3 class="text-[#8ddad2] font-semibold mb-4">
          Contacto
        </h3>
        <ul class="space-y-2 text-sm text-[#E6EDF3]/70">
          <li>
            <a
              href="mailto:info@jctechstudio.es"
              class="hover:text-[#8ddad2] transition-colors flex items-center gap-2"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
              info@jctechstudio.es
            </a>
          </li>
          <li>
            <a
              href="tel:+34684079055"
              class="hover:text-[#8ddad2] transition-colors flex items-center gap-2"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
              +34 684 079 055
            </a>
          </li>
          <li class="flex items-center gap-2">
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
              ></path>
            </svg>
            España
          </li>
          <li>
            <a
              href="https://www.jctechstudio.es"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-[#8ddad2] transition-colors flex items-center gap-2"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.658 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
                ></path>
              </svg>
              www.jctechstudio.es
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-[#589fb8]/20 mt-8 pt-8">
      <div class="mb-6 p-4 bg-primary/10 rounded-lg border border-primary/20">
        <p class="text-xs text-[#E6EDF3]/60 mono">
          ⚡ Esta herramienta utiliza inteligencia artificial de terceros (Groq y OpenRouter) para procesar tus solicitudes. Los datos se envían a sus servidores según sus políticas de privacidad.
        </p>
      </div>
      
      <div
        class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-[#E6EDF3]/60"
      >
        <p>
          © 2026 JCTechStudio. Todos los derechos reservados.
        </p>
        <div class="flex gap-6">
          <a
            href="https://www.jctechstudio.es/politica-privacidad"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[#8ddad2] transition-colors"
          >
            Privacidad
          </a>
          <a
            href="https://www.jctechstudio.es/terminos-condiciones"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[#8ddad2] transition-colors"
          >
            Términos
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>