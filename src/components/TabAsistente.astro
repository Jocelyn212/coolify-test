---
---
<div class="flex flex-col gap-6">
  
  <!-- Header -->
  <div class="mb-6">
    <h2 class="text-3xl font-extrabold tracking-tight mb-2 bg-linear-to-r from-text-light to-accent-mint bg-clip-text text-transparent">Asistente de texto</h2>
    <p class="mono text-sm text-text-secondary">Corrige, mejora o resume cualquier texto en segundos.</p>
  </div>

  <!-- Grid -->
  <div class="grid md:grid-cols-2 gap-6">
    
    <!-- Input -->
    <div class="flex flex-col gap-4">
      <label class="mono text-xs tracking-widest uppercase font-semibold text-accent-mint">Tu texto</label>
      <textarea
        id="asistente-input"
        placeholder="Escribe o pega tu texto aquí..."
        class="min-h-60 border-2 border-primary rounded-xl p-4 text-base placeholder-opacity-60 resize-none focus:outline-none focus:border-accent-mint transition-all bg-primary/30 text-text-light placeholder:text-text-secondary"
      ></textarea>

      <!-- Botones -->
      <div class="grid grid-cols-3 gap-2">
        {[
          { accion: 'corregir', label: '✓ Corregir' },
          { accion: 'mejorar', label: '↑ Mejorar' },
          { accion: 'resumir', label: '◎ Resumir' },
        ].map(({ accion, label }) => (
          <button
            data-accion={accion}
            class="asistente-btn mono text-sm py-3 px-2 border-2 border-primary rounded-lg transition-all font-medium text-primary-light bg-primary/30 hover:border-accent-mint hover:text-accent-mint hover:bg-primary/50"
          >
            {label}
          </button>
        ))}
      </div>
    </div>

    <!-- Output -->
    <div class="flex flex-col gap-4">
      <div class="flex justify-between items-center">
        <label class="mono text-xs tracking-widest uppercase font-semibold text-accent-mint">Resultado</label>
        <div class="flex items-center gap-2">
          <button id="asistente-copiar" class="mono text-sm transition-all font-medium hidden px-3 py-1 rounded text-text-light bg-accent-mint/15 hover:bg-accent-mint/25 hover:text-accent-mint items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 10h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            copiar
          </button>
          <button id="asistente-limpiar" class="mono text-sm transition-all font-medium px-3 py-1 rounded text-text-light bg-primary/40 hover:bg-primary/60">
            limpiar
          </button>
        </div>
      </div>

      <div id="asistente-output" class="relative min-h-60 border-2 border-primary rounded-xl p-4 text-base leading-relaxed transition-all bg-primary/30 text-text-light">
        <span id="asistente-placeholder" class="text-text-secondary">El resultado aparecerá aquí...</span>
        <div id="asistente-loading" class="absolute inset-0 items-center justify-center hidden">
          <div class="flex gap-1">
            <span class="w-3 h-3 rounded-full animate-bounce bg-primary" style="animation-delay:0s;"></span>
            <span class="w-3 h-3 rounded-full animate-bounce bg-primary-light" style="animation-delay:0.15s;"></span>
            <span class="w-3 h-3 rounded-full animate-bounce bg-accent-mint" style="animation-delay:0.3s;"></span>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div id="asistente-stats" class="hidden grid-cols-2 gap-2">
        <div class="border-2 border-primary rounded-lg p-4 bg-primary-dark/30">
          <div id="asistente-tiempo" class="text-lg font-bold text-accent-mint">—</div>
          <div class="mono text-xs uppercase tracking-widest mt-2 text-text-secondary">segundos</div>
        </div>
        <div class="border-2 border-primary rounded-lg p-4 bg-primary-dark/30">
          <div id="asistente-palabras" class="text-lg font-bold text-primary-light">—</div>
          <div class="mono text-xs uppercase tracking-widest mt-2 text-text-secondary">palabras</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const btns = document.querySelectorAll('.asistente-btn');
  const input = document.getElementById('asistente-input') as HTMLTextAreaElement;
  const output = document.getElementById('asistente-output')!;
  const loading = document.getElementById('asistente-loading')!;
  const placeholder = document.getElementById('asistente-placeholder')!;
  const copiarBtn = document.getElementById('asistente-copiar')!;
  const limpiarBtn = document.getElementById('asistente-limpiar')!;
  const stats = document.getElementById('asistente-stats')!;
  const statTiempo = document.getElementById('asistente-tiempo')!;
  const statPalabras = document.getElementById('asistente-palabras')!;

  let resultadoTexto = '';

  btns.forEach(btn => {
    btn.addEventListener('click', async () => {
      const texto = input.value.trim();
      if (!texto) return;

      const accion = btn.getAttribute('data-accion')!;

      placeholder.classList.add('hidden');
      loading.classList.remove('hidden');
      loading.classList.add('flex');
      copiarBtn.classList.add('hidden');
      stats.classList.add('hidden');

      const inicio = Date.now();

      try {
        const res = await fetch('/api/ai', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ texto, accion }),
        });

        const data = await res.json();
        const tiempo = ((Date.now() - inicio) / 1000).toFixed(1);
        const palabras = data.resultado.split(' ').length;

        resultadoTexto = data.resultado;
        loading.classList.add('hidden');
        loading.classList.remove('flex');

        output.innerHTML = '';
        output.style.whiteSpace = 'pre-wrap';
        output.appendChild(document.createTextNode(resultadoTexto));
        output.appendChild(loading);

        copiarBtn.classList.remove('hidden');
        copiarBtn.classList.add('inline-flex');
        stats.classList.remove('hidden');
        stats.classList.add('grid');
        statTiempo.textContent = tiempo + 's';
        statPalabras.textContent = palabras.toString();

      } catch (e) {
        loading.classList.add('hidden');
        loading.classList.remove('flex');
        output.innerHTML = '<span class="text-red-400 mono text-xs">Error al conectar. Inténtalo de nuevo.</span>';
      }
    });
  });

  copiarBtn.addEventListener('click', () => {
    if (!resultadoTexto.trim()) return;
    navigator.clipboard.writeText(resultadoTexto);
    copiarBtn.textContent = '✓ copiado';
    setTimeout(() => {
      copiarBtn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 10h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        copiar
      `;
    }, 2000);
  });

  limpiarBtn.addEventListener('click', () => {
    input.value = '';
    resultadoTexto = '';
    output.innerHTML = '';
    output.appendChild(placeholder);
    output.appendChild(loading);
    placeholder.classList.remove('hidden');
    loading.classList.add('hidden');
    loading.classList.remove('flex');
    copiarBtn.classList.add('hidden');
    copiarBtn.classList.remove('inline-flex');
    stats.classList.add('hidden');
    stats.classList.remove('grid');
    input.focus();
  });
</script>