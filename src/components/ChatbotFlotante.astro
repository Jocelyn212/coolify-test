---
---

<div id="chatbot-container" class="fixed bottom-6 right-6 z-50">
  <!-- Button -->
  <button
    id="chatbot-toggle"
    class="rounded-full w-14 h-14 text-zinc-950 font-bold flex items-center justify-center shadow-lg transition-all hover:scale-110"
    style="background-color: #a778be;"
  >
    💬
  </button>

  <!-- Chat window -->
  <div
    id="chatbot-window"
    class="absolute bottom-20 right-0 w-80 max-h-96 rounded-2xl shadow-2xl flex flex-col overflow-hidden"
    style="background-color: #0B1120; border: 1px solid #2a5d94; display: none;"
  >
    <!-- Header -->
    <div class="border-b p-4" style="background-color: #0B1120; border-color: #2a5d94;">
      <h3 class="font-bold mono text-sm" style="color: #a778be;">Asistente IA</h3>
      <p class="mono text-xs mt-1" style="color: #589fb8;">¿En qué puedo ayudarte?</p>
    </div>

    <!-- Messages -->
    <div id="chatbot-messages" class="flex-1 overflow-y-auto p-4 space-y-3">
      <div class="flex justify-start">
        <div class="rounded-lg rounded-tl-none px-3 py-2 max-w-xs" style="background-color: #2a5d94;">
          <p style="color: #E6EDF3;" class="text-sm">¡Hola! Soy tu asistente IA. ¿Cómo puedo ayudarte?</p>
        </div>
      </div>
    </div>

    <!-- Input -->
    <div class="border-t p-4" style="background-color: #0B1120; border-color: #2a5d94;">
      <form id="chatbot-form" class="flex gap-2">
        <input
          id="chatbot-input"
          type="text"
          placeholder="Escribe tu pregunta..."
          class="flex-1 border rounded-lg px-3 py-2 text-sm focus:outline-none transition-colors"
          style="background-color: #2a5d94; border-color: #589fb8; color: #E6EDF3;"
          onfocus="this.style.borderColor='#a778be'; this.style.boxShadow='0 0 0 2px rgba(167, 120, 190, 0.1)'"
          onblur="this.style.borderColor='#589fb8'; this.style.boxShadow='none'"
          autocomplete="off"
        />
        <button
          type="submit"
          class="font-bold px-4 py-2 rounded-lg transition-colors mono text-xs text-zinc-950"
          style="background-color: #a778be;"
        >
          →
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('chatbot-toggle')!;
  const window = document.getElementById('chatbot-window')!;
  const messagesContainer = document.getElementById('chatbot-messages')!;
  const form = document.getElementById('chatbot-form')!;
  const input = document.getElementById('chatbot-input') as HTMLInputElement;

  let isOpen = false;

  toggle.addEventListener('click', () => {
    isOpen = !isOpen;
    window.style.display = isOpen ? 'flex' : 'none';
    if (isOpen) {
      input.focus();
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const mensaje = input.value.trim();
    if (!mensaje) return;

    // User message
    const userDiv = document.createElement('div');
    userDiv.className = 'flex justify-end';
    const userMsg = document.createElement('div');
    userMsg.className = 'rounded-lg rounded-tr-none px-3 py-2 max-w-xs text-sm';
    userMsg.style.backgroundColor = '#589fb8';
    userMsg.style.color = '#E6EDF3';
    userMsg.innerHTML = `<p>${mensaje}</p>`;
    userDiv.appendChild(userMsg);
    messagesContainer.appendChild(userDiv);

    input.value = '';

    // Loading indicator
    const loadingDiv = document.createElement('div');
    loadingDiv.className = 'flex justify-start';
    const loadingMsg = document.createElement('div');
    loadingMsg.className = 'rounded-lg rounded-tl-none px-3 py-2';
    loadingMsg.style.backgroundColor = '#2a5d94';
    loadingMsg.innerHTML = `
      <div class="flex gap-1">
        <span class="w-2 h-2 rounded-full animate-bounce" style="animation-delay:0s; background-color: #a778be;"></span>
        <span class="w-2 h-2 rounded-full animate-bounce" style="animation-delay:0.15s; background-color: #a778be;"></span>
        <span class="w-2 h-2 rounded-full animate-bounce" style="animation-delay:0.3s; background-color: #a778be;"></span>
      </div>
    `;
    loadingDiv.appendChild(loadingMsg);
    const loadingId = messagesContainer.appendChild(loadingDiv);

    // Scroll to bottom
    setTimeout(() => {
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }, 0);

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mensaje }),
      });

      const data = await res.json();

      // Remove loading
      loadingDiv.remove();

      // Bot message
      const botDiv = document.createElement('div');
      botDiv.className = 'flex justify-start';
      const botMsg = document.createElement('div');
      botMsg.className = 'rounded-lg rounded-tl-none px-3 py-2 max-w-xs text-sm';
      botMsg.style.backgroundColor = '#2a5d94';
      botMsg.style.color = '#E6EDF3';
      botMsg.innerHTML = `<p>${data.respuesta}</p>`;
      botDiv.appendChild(botMsg);
      messagesContainer.appendChild(botDiv);

      // Scroll to bottom
      setTimeout(() => {
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
      }, 0);

    } catch (e) {
      loadingDiv.remove();
      const errorDiv = document.createElement('div');
      errorDiv.className = 'flex justify-start';
      const errorMsg = document.createElement('div');
      errorMsg.className = 'rounded-lg rounded-tl-none px-3 py-2 text-xs mono';
      errorMsg.style.backgroundColor = '#a778be';
      errorMsg.style.color = '#E6EDF3';
      errorMsg.innerHTML = `<p>Error al conectar. Inténtalo de nuevo.</p>`;
      errorDiv.appendChild(errorMsg);
      messagesContainer.appendChild(errorDiv);
    }
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      isOpen = false;
      window.classList.add('hidden');
    }
  });
</script>

<style>
  .mono { font-family: 'DM Mono', monospace; }
  
  #chatbot-messages {
    scrollbar-width: thin;
    scrollbar-color: #2a5d94 transparent;
  }

  #chatbot-messages::-webkit-scrollbar {
    width: 6px;
  }

  #chatbot-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  #chatbot-messages::-webkit-scrollbar-thumb {
    background-color: #2a5d94;
    border-radius: 3px;
  }
</style>
