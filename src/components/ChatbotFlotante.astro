---
---

<div id="chatbot-container" class="fixed bottom-4 right-4 md:bottom-6 md:right-6 z-50">
  <!-- Button -->
  <button
    id="chatbot-toggle"
    class="rounded-full w-14 h-14 font-bold flex items-center justify-center shadow-lg transition-all hover:scale-110 text-2xl relative z-50 bg-highlight-lila text-bg-dark"
  >
    💬
  </button>

  <!-- Chat window -->
  <div
    id="chatbot-window"
    class="fixed bottom-20 right-4 md:right-6 w-[calc(100vw-2rem)] max-w-sm md:max-w-md rounded-2xl shadow-2xl flex flex-col overflow-hidden z-40 bg-bg-dark border border-primary hidden h-[480px]"
  >
    <!-- Header -->
    <div class="border-b border-primary p-4 flex justify-between items-start flex-shrink-0 bg-bg-dark">
      <div>
        <h3 class="font-bold mono text-sm text-highlight-lila">Asistente IA</h3>
        <p class="mono text-xs mt-1 text-primary-light">¿En qué puedo ayudarte?</p>
      </div>
      <button
        id="chatbot-close"
        class="text-xl font-bold transition-all hover:scale-110 hover:opacity-70 text-highlight-lila"
      >
        ✕
      </button>
    </div>

    <!-- Messages -->
    <div id="chatbot-messages" class="flex-1 overflow-y-auto p-4 space-y-3 min-h-0 bg-bg-dark">
      <div class="flex justify-start">
        <div class="rounded-lg rounded-tl-none px-3 py-2 max-w-[80%] bg-primary">
          <p class="text-sm text-text-light">¡Hola! Soy tu asistente IA. ¿Cómo puedo ayudarte?</p>
        </div>
      </div>
    </div>

    <!-- Input -->
    <div class="border-t border-primary p-3 flex-shrink-0 bg-bg-dark">
      <form id="chatbot-form" class="flex gap-2">
        <input
          id="chatbot-input"
          type="text"
          placeholder="Escribe tu pregunta..."
          class="flex-1 border border-primary-light rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-highlight-lila transition-colors bg-primary text-text-light placeholder:text-text-secondary"
          autocomplete="off"
        />
        <button
          type="submit"
          class="font-bold px-4 py-2 rounded-lg transition-all hover:opacity-80 mono text-xs text-bg-dark flex-shrink-0 bg-highlight-lila"
        >
          →
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  const toggleBtn = document.getElementById('chatbot-toggle')!;
  const chatWindow = document.getElementById('chatbot-window')!;
  const closeBtn = document.getElementById('chatbot-close')!;
  const messagesContainer = document.getElementById('chatbot-messages')!;
  const form = document.getElementById('chatbot-form')!;
  const chatInput = document.getElementById('chatbot-input') as HTMLInputElement;

  let isOpen = false;

  const scrollToBottom = () => {
    setTimeout(() => {
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }, 50);
  };

  const closeChat = () => {
    isOpen = false;
    chatWindow.classList.add('hidden');
  };

  const openChat = () => {
    isOpen = true;
    chatWindow.classList.remove('hidden');
    chatInput.focus();
    scrollToBottom();
  };

  toggleBtn.addEventListener('click', () => {
    isOpen ? closeChat() : openChat();
  });

  closeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    closeChat();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeChat();
  });

  const addMessage = (texto: string, esUsuario: boolean) => {
    const wrapper = document.createElement('div');
    wrapper.className = `flex ${esUsuario ? 'justify-end' : 'justify-start'}`;

    const bubble = document.createElement('div');
    bubble.className = `px-3 py-2 max-w-[80%] text-sm rounded-lg ${
      esUsuario
        ? 'bg-primary-light text-text-light rounded-br-none'
        : 'bg-primary text-text-light rounded-bl-none'
    }`;
    bubble.innerHTML = `<p class="whitespace-pre-wrap">${texto}</p>`;

    wrapper.appendChild(bubble);
    messagesContainer.appendChild(wrapper);
    scrollToBottom();
    return wrapper;
  };

  const addLoading = () => {
    const wrapper = document.createElement('div');
    wrapper.className = 'flex justify-start';
    wrapper.innerHTML = `
      <div class="px-3 py-2 bg-primary rounded-lg rounded-bl-none">
        <div class="flex gap-1">
          <span class="w-2 h-2 rounded-full animate-bounce bg-highlight-lila" style="animation-delay:0s;"></span>
          <span class="w-2 h-2 rounded-full animate-bounce bg-highlight-lila" style="animation-delay:0.15s;"></span>
          <span class="w-2 h-2 rounded-full animate-bounce bg-highlight-lila" style="animation-delay:0.3s;"></span>
        </div>
      </div>
    `;
    messagesContainer.appendChild(wrapper);
    scrollToBottom();
    return wrapper;
  };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const mensaje = chatInput.value.trim();
    if (!mensaje) return;

    addMessage(mensaje, true);
    chatInput.value = '';

    const loadingEl = addLoading();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mensaje }),
      });

      const data = await res.json();
      loadingEl.remove();
      addMessage(data.respuesta, false);

    } catch (err) {
      loadingEl.remove();
      addMessage('Error al conectar. Inténtalo de nuevo.', false);
    }
  });
</script>

<style>
  #chatbot-messages {
    scrollbar-width: thin;
    scrollbar-color: var(--primary) transparent;
  }
  #chatbot-messages::-webkit-scrollbar { width: 4px; }
  #chatbot-messages::-webkit-scrollbar-track { background: transparent; }
  #chatbot-messages::-webkit-scrollbar-thumb {
    background-color: var(--primary);
    border-radius: 3px;
  }
</style>
