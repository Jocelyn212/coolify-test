---
---
<div class="flex flex-col gap-6">

  <!-- Header -->
  <div class="mb-6">
    <h2 class="text-3xl font-extrabold tracking-tight mb-2 bg-linear-to-r from-text-light to-accent-mint bg-clip-text text-transparent">
      Posts para Redes Sociales
    </h2>
    <p class="mono text-sm text-text-secondary">Adapta tu contenido a diferentes plataformas.</p>
  </div>

  <!-- Grid -->
  <div class="grid md:grid-cols-2 gap-6">

    <!-- Input -->
    <div class="flex flex-col gap-4">
      <div>
        <label class="mono text-xs tracking-widest uppercase font-semibold text-accent-mint">Plataforma</label>
        <div class="grid grid-cols-2 gap-2 mt-2">
          {[
            { label: '𝕏 Twitter/X', value: 'Twitter (máximo 280 caracteres, directo y viral)' },
            { label: '📷 Instagram', value: 'Instagram (visual, emojis, hashtags, máximo 2200 caracteres)' },
            { label: '💼 LinkedIn', value: 'LinkedIn (profesional, detallado, networking)' },
            { label: '🎵 TikTok', value: 'TikTok (trending, casual, juvenil, máximo 150 caracteres)' },
          ].map(({ label, value }) => (
            <button
              data-plataforma={value}
              class="plataforma-btn mono text-sm py-2 px-3 border-2 border-primary rounded-lg transition-all text-primary-light bg-primary/30 hover:border-accent-mint hover:text-accent-mint hover:bg-primary/50"
            >
              {label}
            </button>
          ))}
        </div>
      </div>

      <div>
        <label class="mono text-xs tracking-widest uppercase font-semibold text-accent-mint">Contenido original</label>
        <textarea
          id="redes-input"
          placeholder="Escribe o pega el contenido que quieres adaptar..."
          class="w-full mt-2 min-h-48 border-2 border-primary rounded-xl p-4 text-sm resize-none focus:outline-none focus:border-accent-mint transition-all bg-primary/30 text-text-light placeholder:text-text-secondary"
        ></textarea>
      </div>

      <button
        id="redes-btn"
        disabled
        class="mono text-sm py-3 px-4 rounded-lg transition-all font-medium border-2 border-primary text-primary-light bg-primary/50 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        ↑ Generar Post
      </button>
    </div>

    <!-- Output -->
    <div class="flex flex-col gap-4">
      <div class="flex justify-between items-center">
        <label class="mono text-xs tracking-widest uppercase font-semibold text-accent-mint">
          <span id="redes-plataforma-label">Post generado</span>
        </label>
        <div class="flex items-center gap-2">
          <button id="redes-copiar" class="mono text-sm transition-all font-medium hidden px-3 py-1 rounded text-text-light bg-accent-mint/15 hover:bg-accent-mint/25 hover:text-accent-mint items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 10h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            copiar
          </button>
          <button id="redes-limpiar" class="mono text-sm transition-all font-medium px-3 py-1 rounded text-text-light bg-primary/40 hover:bg-primary/60">
            limpiar
          </button>
        </div>
      </div>

      <div
        id="redes-output"
        class="relative min-h-48 border-2 border-primary rounded-xl p-4 text-sm leading-relaxed text-text-light bg-primary-dark/30"
      >
        <span id="redes-placeholder" class="text-text-secondary">Selecciona una plataforma y genera tu post...</span>
        <div id="redes-loading" class="absolute inset-0 items-center justify-center hidden">
          <div class="flex gap-1">
            <span class="w-3 h-3 rounded-full animate-bounce bg-primary" style="animation-delay:0s;"></span>
            <span class="w-3 h-3 rounded-full animate-bounce bg-primary-light" style="animation-delay:0.15s;"></span>
            <span class="w-3 h-3 rounded-full animate-bounce bg-accent-mint" style="animation-delay:0.3s;"></span>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div id="redes-stats" class="hidden grid-cols-2 gap-2">
        <div class="border-2 border-primary rounded-lg p-4 bg-primary-dark/30">
          <div id="redes-tiempo" class="text-lg font-bold text-accent-mint">—</div>
          <div class="mono text-xs uppercase tracking-widest mt-2 text-text-secondary">segundos</div>
        </div>
        <div class="border-2 border-primary rounded-lg p-4 bg-primary-dark/30">
          <div id="redes-caracteres" class="text-lg font-bold text-primary-light">—</div>
          <div class="mono text-xs uppercase tracking-widest mt-2 text-text-secondary">caracteres</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('redes-btn') as HTMLButtonElement;
  const input = document.getElementById('redes-input') as HTMLTextAreaElement;
  const output = document.getElementById('redes-output')!;
  const loading = document.getElementById('redes-loading')!;
  const placeholder = document.getElementById('redes-placeholder')!;
  const copiarBtn = document.getElementById('redes-copiar')!;
  const limpiarBtn = document.getElementById('redes-limpiar')!;
  const stats = document.getElementById('redes-stats')!;
  const statTiempo = document.getElementById('redes-tiempo')!;
  const statCaracteres = document.getElementById('redes-caracteres')!;
  const plataformaLabel = document.getElementById('redes-plataforma-label')!;
  const platformaBtns = document.querySelectorAll('.plataforma-btn');

  let selectedPlatforma = '';
  let resultadoTexto = '';

  platformaBtns.forEach(b => {
    b.addEventListener('click', () => {
      platformaBtns.forEach(pb => {
        pb.classList.remove('border-accent-mint', 'text-accent-mint', 'bg-accent-mint/25');
        pb.classList.add('border-primary', 'text-primary-light', 'bg-primary/30');
      });

      b.classList.remove('border-primary', 'text-primary-light', 'bg-primary/30');
      b.classList.add('border-accent-mint', 'text-accent-mint', 'bg-accent-mint/25');

      selectedPlatforma = b.getAttribute('data-plataforma') || '';
      plataformaLabel.textContent = b.textContent || 'Post generado';

      btn.disabled = false;
      btn.classList.remove('border-primary', 'text-primary-light');
      btn.classList.add('border-accent-mint', 'text-accent-mint');
    });
  });

  btn?.addEventListener('click', async () => {
    const texto = input.value.trim();
    if (!texto || !selectedPlatforma) return;

    placeholder.classList.add('hidden');
    loading.classList.remove('hidden');
    loading.classList.add('flex');
    copiarBtn.classList.add('hidden');
    stats.classList.add('hidden');

    const inicio = Date.now();

    try {
      const res = await fetch('/api/ai', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          texto,
          accion: 'redes',
          metadata: { plataforma: selectedPlatforma }
        }),
      });

      const data = await res.json();
      const tiempo = ((Date.now() - inicio) / 1000).toFixed(1);
      const caracteres = data.resultado.length;

      resultadoTexto = data.resultado;
      loading.classList.add('hidden');
      loading.classList.remove('flex');

      output.innerHTML = '';
      output.className = 'relative min-h-48 border-2 border-primary rounded-xl p-4 text-sm leading-relaxed text-text-light bg-primary-dark/30 whitespace-pre-wrap';
      output.appendChild(document.createTextNode(resultadoTexto));

      copiarBtn.classList.remove('hidden');
      copiarBtn.classList.add('inline-flex');
      stats.classList.remove('hidden');
      stats.classList.add('grid');
      statTiempo.textContent = tiempo + 's';
      statCaracteres.textContent = caracteres.toString();

    } catch (e) {
      loading.classList.add('hidden');
      loading.classList.remove('flex');
      output.innerHTML = '<span class="text-red-400 mono text-xs">Error al generar el post. Inténtalo de nuevo.</span>';
    }
  });

  copiarBtn.addEventListener('click', () => {
    if (!resultadoTexto.trim()) return;
    navigator.clipboard.writeText(resultadoTexto);
    copiarBtn.textContent = '✓ copiado';
    setTimeout(() => {
      copiarBtn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 10h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        copiar
      `;
    }, 2000);
  });

  limpiarBtn.addEventListener('click', () => {
    input.value = '';
    resultadoTexto = '';
    selectedPlatforma = '';
    plataformaLabel.textContent = 'Post generado';
    btn.disabled = true;
    btn.classList.remove('border-accent-mint', 'text-accent-mint');
    btn.classList.add('border-primary', 'text-primary-light');
    platformaBtns.forEach(pb => {
      pb.classList.remove('border-accent-mint', 'text-accent-mint', 'bg-accent-mint/25');
      pb.classList.add('border-primary', 'text-primary-light', 'bg-primary/30');
    });
    output.innerHTML = '';
    output.appendChild(placeholder);
    output.appendChild(loading);
    placeholder.classList.remove('hidden');
    loading.classList.add('hidden');
    loading.classList.remove('flex');
    copiarBtn.classList.add('hidden');
    copiarBtn.classList.remove('inline-flex');
    stats.classList.add('hidden');
    stats.classList.remove('grid');
    input.focus();
  });
</script>
