---
import TabAsistente from './TabAsistente.astro';
import TabChat from './TabChat.astro';
import TabEmail from './TabEmail.astro';
import TabRedes from './TabRedes.astro';
import TabTraductor from './TabTraductor.astro';
---

<main class="pt-32 min-h-screen bg-bg-deeper">
  
  <!-- Tab buttons -->
  <div class="sticky top-0 z-40 backdrop-blur-md border-b border-zinc-800 bg-bg-deeper/90">
    <div class="max-w-5xl mx-auto px-4">
      <div class="flex overflow-x-auto scrollbar-none gap-1 py-2">
        {[
          { id: 'asistente', label: '✓ Texto' },
          { id: 'email', label: '✉ Email' },
          { id: 'redes', label: '◎ Redes' },
          { id: 'traductor', label: '⇄ Traducir' },
          { id: 'chat', label: '💬 Chat' },
        ].map(tab => (
          <button
            data-tab={tab.id}
            class="tab-btn shrink-0 mono text-xs px-4 py-2 rounded-lg border-2 transition-all whitespace-nowrap border-primary text-text-light bg-transparent hover:border-primary/50"
          >
            {tab.label}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Tab content -->
  <div class="max-w-5xl mx-auto px-4 py-8">
    <div id="tab-asistente" class="tab-content">
      <TabAsistente />
    </div>
    <div id="tab-chat" class="tab-content hidden">
      <TabChat />
    </div>
    <div id="tab-email" class="tab-content hidden">
      <TabEmail />
    </div>
    <div id="tab-redes" class="tab-content hidden">
      <TabRedes />
    </div>
    <div id="tab-traductor" class="tab-content hidden">
      <TabTraductor />
    </div>
  </div>

</main>

<script>
  const btns = document.querySelectorAll('.tab-btn');
  const contents = document.querySelectorAll('.tab-content');

  function activateTab(id: string) {
    btns.forEach(btn => {
      const isActive = btn.getAttribute('data-tab') === id;
      if (isActive) {
        btn.classList.remove('border-primary', 'text-text-light', 'bg-transparent', 'hover:border-primary/50');
        btn.classList.add('border-accent-mint', 'text-accent-mint', 'bg-accent-mint/10');
      } else {
        btn.classList.remove('border-accent-mint', 'text-accent-mint', 'bg-accent-mint/10');
        btn.classList.add('border-primary', 'text-text-light', 'bg-transparent', 'hover:border-primary/50');
      }
    });
    contents.forEach(content => {
      content.classList.toggle('hidden', content.id !== `tab-${id}`);
    });
  }

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      activateTab(btn.getAttribute('data-tab')!);
    });
  });

  // Activar primera pestaña por defecto
  activateTab('asistente');
</script>