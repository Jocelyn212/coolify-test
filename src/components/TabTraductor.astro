---
---

<div class="flex flex-col gap-6">
  
  <!-- Header -->
  <div class="mb-6">
    <h2 class="text-3xl font-extrabold tracking-tight mb-2 bg-linear-to-r from-text-light to-accent-mint bg-clip-text text-transparent">Traductor de Textos</h2>
    <p class="mono text-sm text-text-secondary">Traduce tu texto a diferentes idiomas.</p>
  </div>

  <!-- Grid -->
  <div class="grid md:grid-cols-2 gap-6">
    
    <!-- Input -->
    <div class="flex flex-col gap-4">
      <div>
        <label class="mono text-xs tracking-widest uppercase font-semibold text-accent-mint">Idioma destino</label>
        <select
          id="traductor-idioma"
          class="w-full mt-2 border-2 border-primary rounded-lg p-3 text-base focus:outline-none focus:border-accent-mint transition-all bg-primary/30 text-text-light"
        >
          <option value="español">🇪🇸 Español</option>
          <option value="catalán">⭐ Catalán</option>
          <option value="inglés">🇬🇧 Inglés</option>
          <option value="francés">🇫🇷 Francés</option>
          <option value="alemán">🇩🇪 Alemán</option>
          <option value="italiano">🇮🇹 Italiano</option>
          <option value="portugués">🇵🇹 Portugués</option>
          <option value="holandés">🇳🇱 Holandés</option>
          <option value="ruso">🇷🇺 Ruso</option>
          <option value="japonés">🇯🇵 Japonés</option>
          <option value="chino mandarin">🇨🇳 Chino Mandarín</option>
          <option value="árabe">🇸🇦 Árabe</option>
          <option value="coreano">🇰🇷 Coreano</option>
          <option value="vietnamita">🇻🇳 Vietnamita</option>
        </select>
      </div>

      <div>
        <label class="mono text-xs tracking-widest uppercase font-semibold text-accent-mint">Texto a traducir</label>
        <textarea
          id="traductor-input"
          placeholder="Escribe o pega el texto que deseas traducir..."
          class="w-full mt-2 min-h-60 border-2 border-primary rounded-lg p-4 text-base resize-none focus:outline-none focus:border-accent-mint transition-all bg-primary/30 text-text-light placeholder:text-text-secondary"
        ></textarea>
      </div>

      <button
        id="traductor-btn"
        class="mono text-sm py-3 px-4 rounded-lg transition-all font-semibold text-zinc-950 bg-accent-mint hover:shadow-lg hover:bg-accent-mint/90"
      >
        ⇄ Traducir
      </button>
    </div>

    <!-- Output -->
    <div class="flex flex-col gap-4">
      <div class="flex justify-between items-center">
        <label class="mono text-xs tracking-widest uppercase font-semibold text-accent-mint">Traducción</label>
        <div class="flex items-center gap-2">
          <button id="traductor-copiar" class="mono text-sm transition-all font-medium hidden px-3 py-1 rounded text-text-light bg-accent-mint/15 hover:bg-accent-mint/25 hover:text-accent-mint items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 10h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            copiar
          </button>
          <button id="traductor-limpiar" class="mono text-sm transition-all font-medium px-3 py-1 rounded text-text-light bg-primary/40 hover:bg-primary/60">
            limpiar
          </button>
        </div>
      </div>

      <div id="traductor-output" class="relative min-h-60 border-2 border-primary rounded-lg p-4 text-base leading-relaxed bg-primary/30 text-text-light">
        <span id="traductor-placeholder" class="text-text-secondary">La traducción aparecerá aquí...</span>
        <div id="traductor-loading" class="absolute inset-0 items-center justify-center hidden">
          <div class="flex gap-1">
            <span class="w-2 h-2 rounded-full animate-bounce bg-accent-mint" style="animation-delay:0s;"></span>
            <span class="w-2 h-2 rounded-full animate-bounce bg-primary-light" style="animation-delay:0.15s;"></span>
            <span class="w-2 h-2 rounded-full animate-bounce bg-accent-mint" style="animation-delay:0.3s;"></span>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div id="traductor-stats" class="hidden grid-cols-2 gap-3">
        <div class="border-2 border-primary rounded-lg p-3 bg-primary-dark/30">
          <div id="traductor-tiempo" class="text-lg font-bold text-accent-mint">—</div>
          <div class="mono text-xs uppercase tracking-widest text-text-secondary">segundos</div>
        </div>
        <div class="border-2 border-primary rounded-lg p-3 bg-primary-dark/30">
          <div id="traductor-caracteres" class="text-lg font-bold text-text-light">—</div>
          <div class="mono text-xs uppercase tracking-widest text-text-secondary">caracteres</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('traductor-btn');
  const idiomaSelect = document.getElementById('traductor-idioma') as HTMLSelectElement;
  const input = document.getElementById('traductor-input') as HTMLTextAreaElement;
  const output = document.getElementById('traductor-output')!;
  const loading = document.getElementById('traductor-loading')!;
  const placeholder = document.getElementById('traductor-placeholder')!;
  const copiarBtn = document.getElementById('traductor-copiar')!;
  const limpiarBtn = document.getElementById('traductor-limpiar')!;
  const stats = document.getElementById('traductor-stats')!;
  const statTiempo = document.getElementById('traductor-tiempo')!;
  const statCaracteres = document.getElementById('traductor-caracteres')!;

  let resultadoTexto = '';

  btn?.addEventListener('click', async () => {
    const texto = input.value.trim();
    if (!texto) return;

    const idioma = idiomaSelect.value;

    placeholder.classList.add('hidden');
    loading.classList.remove('hidden');
    copiarBtn.classList.add('hidden');
    stats.classList.add('hidden');

    const inicio = Date.now();

    try {
      const res = await fetch('/api/ai', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          texto,
          accion: 'traducir',
          metadata: { idioma }
        }),
      });

      const data = await res.json();
      const tiempo = ((Date.now() - inicio) / 1000).toFixed(1);
      const caracteres = data.resultado.length;

      resultadoTexto = data.resultado;
      loading.classList.add('hidden');

      output.innerHTML = '';
      output.className = 'relative min-h-60 border-2 border-primary rounded-lg p-4 text-base leading-relaxed bg-primary/30 text-text-light whitespace-pre-wrap';
      output.appendChild(document.createTextNode(resultadoTexto));

      copiarBtn.classList.remove('hidden');
      copiarBtn.classList.add('inline-flex');
      stats.classList.remove('hidden');
      stats.classList.add('grid');
      statTiempo.textContent = tiempo + 's';
      statCaracteres.textContent = caracteres.toString();

    } catch (e) {
      loading.classList.add('hidden');
      output.innerHTML = '<span class="text-red-400 mono text-xs">Error al traducir. Inténtalo de nuevo.</span>';
    }
  });

  copiarBtn.addEventListener('click', () => {
    if (!resultadoTexto.trim()) return;
    navigator.clipboard.writeText(resultadoTexto);
    copiarBtn.textContent = '✓ copiado';
    setTimeout(() => {
      copiarBtn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 10h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        copiar
      `;
    }, 2000);
  });

  limpiarBtn.addEventListener('click', () => {
    idiomaSelect.selectedIndex = 0;
    input.value = '';
    resultadoTexto = '';
    output.innerHTML = '';
    output.appendChild(placeholder);
    output.appendChild(loading);
    placeholder.classList.remove('hidden');
    loading.classList.add('hidden');
    copiarBtn.classList.add('hidden');
    copiarBtn.classList.remove('inline-flex');
    stats.classList.add('hidden');
    stats.classList.remove('grid');
    input.focus();
  });
</script>
