---
---

<div class="flex flex-col gap-6">
  
  <!-- Header -->
  <div class="mb-6">
    <h2 class="text-3xl font-extrabold tracking-tight mb-2" style="background: linear-gradient(135deg, #E6EDF3 0%, #8ddad2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Generador de Emails</h2>
    <p class="mono text-sm" style="color: #b0b8c4;">Crea emails profesionales adaptados a tu necesidad.</p>
  </div>

  <!-- Grid -->
  <div class="grid md:grid-cols-2 gap-6">
    
    <!-- Input -->
    <div class="flex flex-col gap-4">
      <div>
        <label class="mono text-xs tracking-widest uppercase font-semibold" style="color: #8ddad2;">Asunto</label>
        <input
          id="email-asunto"
          type="text"
          placeholder="Ej: Propuesta de colaboración"
          class="w-full mt-2 border-2 rounded-lg p-3 text-sm focus:outline-none transition-all"
          style="background: linear-gradient(135deg, rgba(13, 59, 102, 0.3) 0%, rgba(11, 17, 32, 0.8) 100%); border-color: #2a5d94; color: #E6EDF3;"
          onfocus="this.style.borderColor='#8ddad2'; this.style.boxShadow='0 0 20px rgba(141, 218, 210, 0.2)'"
          onblur="this.style.borderColor='#2a5d94'; this.style.boxShadow='none'"
        />
      </div>

      <div>
        <label class="mono text-xs tracking-widest uppercase font-semibold" style="color: #8ddad2;">Tono</label>
        <select
          id="email-tono"
          class="w-full mt-2 border-2 rounded-lg p-3 text-sm focus:outline-none transition-all"
          style="background: linear-gradient(135deg, rgba(13, 59, 102, 0.3) 0%, rgba(11, 17, 32, 0.8) 100%); border-color: #2a5d94; color: #E6EDF3;"
          onfocus="this.style.borderColor='#8ddad2'; this.style.boxShadow='0 0 20px rgba(141, 218, 210, 0.2)'"
          onblur="this.style.borderColor='#2a5d94'; this.style.boxShadow='none'"
        >
          <option value="formal">Formal y profesional</option>
          <option value="semi-formal">Semi-formal</option>
          <option value="amigable">Amigable pero profesional</option>
        </select>
      </div>

      <div>
        <label class="mono text-xs tracking-widest uppercase font-semibold" style="color: #8ddad2;">Contenido</label>
        <textarea
          id="email-input"
          placeholder="Describe qué quieres comunicar..."
          class="w-full mt-2 min-h-50 border-2 rounded-xl p-4 text-sm resize-none focus:outline-none transition-all"
          style="background: linear-gradient(135deg, rgba(13, 59, 102, 0.3) 0%, rgba(11, 17, 32, 0.8) 100%); border-color: #2a5d94; color: #E6EDF3;"
          onfocus="this.style.borderColor='#8ddad2'; this.style.boxShadow='0 0 20px rgba(141, 218, 210, 0.2)'"
          onblur="this.style.borderColor='#2a5d94'; this.style.boxShadow='none'"
        ></textarea>
      </div>

      <button
        id="email-btn"
        class="mono text-sm py-3 px-4 rounded-lg transition-all font-medium text-zinc-950"
        style="background-color: #8ddad2;"
        onmouseover="this.style.backgroundColor='#7dd0ca'; this.style.boxShadow='0 10px 30px rgba(141, 218, 210, 0.3)'"
        onmouseout="this.style.backgroundColor='#8ddad2'; this.style.boxShadow='none'"
      >
        ✓ Generar Email
      </button>
    </div>

    <!-- Output -->
    <div class="flex flex-col gap-4">
      <div class="flex justify-between items-center">
        <label class="mono text-xs tracking-widest uppercase font-semibold" style="color: #8ddad2;">Email generado</label>
        <button id="email-copiar" class="mono text-sm transition-all font-medium hidden px-3 py-1 rounded" style="color: #E6EDF3; background: rgba(141, 218, 210, 0.15);" onmouseover="this.style.background='rgba(141, 218, 210, 0.25)'; this.style.color='#8ddad2'" onmouseout="this.style.background='rgba(141, 218, 210, 0.15)'; this.style.color='#E6EDF3'">
          copiar →
        </button>
      </div>

      <div id="email-output" class="relative min-h-60 border-2 rounded-xl p-4 text-sm leading-relaxed transition-all" style="background: linear-gradient(135deg, rgba(13, 59, 102, 0.3) 0%, rgba(11, 17, 32, 0.8) 100%); border-color: #2a5d94; color: #E6EDF3;">
        <span id="email-placeholder" style="color: #b0b8c4;">El email aparecerá aquí...</span>
        <div id="email-loading" class="absolute inset-0 items-center justify-center" style="display: none;">
          <div class="flex gap-1">
            <span class="w-3 h-3 rounded-full animate-bounce" style="animation-delay:0s; background: linear-gradient(135deg, #2a5d94, #8ddad2);"></span>
            <span class="w-3 h-3 rounded-full animate-bounce" style="animation-delay:0.15s; background: linear-gradient(135deg, #589fb8, #8ddad2);"></span>
            <span class="w-3 h-3 rounded-full animate-bounce" style="animation-delay:0.3s; background: linear-gradient(135deg, #8ddad2, #589fb8);"></span>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div id="email-stats" class="grid grid-cols-2 gap-2" style="display: none;">
        <div class="border-2 rounded-lg p-4 transition-all" style="background: linear-gradient(135deg, rgba(13, 59, 102, 0.3) 0%, rgba(11, 17, 32, 0.8) 100%); border-color: #2a5d94;">
          <div id="email-tiempo" class="text-lg font-bold" style="color: #8ddad2;">—</div>
          <div class="mono text-xs uppercase tracking-widest mt-2" style="color: #b0b8c4;">segundos</div>
        </div>
        <div class="border-2 rounded-lg p-4 transition-all" style="background: linear-gradient(135deg, rgba(13, 59, 102, 0.3) 0%, rgba(11, 17, 32, 0.8) 100%); border-color: #2a5d94;">
          <div id="email-palabras" class="text-lg font-bold" style="color: #589fb8;">—</div>
          <div class="mono text-xs uppercase tracking-widest mt-2" style="color: #b0b8c4;">palabras</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('email-btn');
  const asuntoInput = document.getElementById('email-asunto') as HTMLInputElement;
  const tonoSelect = document.getElementById('email-tono') as HTMLSelectElement;
  const input = document.getElementById('email-input') as HTMLTextAreaElement;
  const output = document.getElementById('email-output')!;
  const loading = document.getElementById('email-loading')!;
  const placeholder = document.getElementById('email-placeholder')!;
  const copiarBtn = document.getElementById('email-copiar')!;
  const stats = document.getElementById('email-stats')!;
  const statTiempo = document.getElementById('email-tiempo')!;
  const statPalabras = document.getElementById('email-palabras')!;

  let resultadoTexto = '';

  btn?.addEventListener('click', async () => {
    const asunto = asuntoInput.value.trim();
    const tono = tonoSelect.value;
    const texto = input.value.trim();
    
    if (!asunto || !texto) return;

    placeholder.classList.add('hidden');
    loading.classList.remove('hidden');
    copiarBtn.classList.add('hidden');
    stats.classList.add('hidden');

    const inicio = Date.now();

    try {
      const res = await fetch('/api/ai', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          texto, 
          accion: 'email',
          metadata: { asunto, tono }
        }),
      });

      const data = await res.json();
      const tiempo = ((Date.now() - inicio) / 1000).toFixed(1);
      const palabras = data.resultado.split(' ').length;

      resultadoTexto = data.resultado;
      loading.classList.add('hidden');

      output.innerHTML = '';
      output.style.whiteSpace = 'pre-wrap';
      output.classList.add('text-zinc-100');
      output.appendChild(document.createTextNode(resultadoTexto));
      output.appendChild(loading);

      copiarBtn.classList.remove('hidden');
      stats.classList.remove('hidden');
      statTiempo.textContent = tiempo + 's';
      statPalabras.textContent = palabras.toString();

    } catch (e) {
      loading.classList.add('hidden');
      output.innerHTML = '<span class="text-red-400 mono text-xs">Error al generar el email. Inténtalo de nuevo.</span>';
    }
  });

  copiarBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(resultadoTexto);
    copiarBtn.textContent = '✓ copiado';
    setTimeout(() => copiarBtn.textContent = 'copiar →', 2000);
  });
</script>

<style>
  .mono { font-family: 'DM Mono', monospace; }
</style>
