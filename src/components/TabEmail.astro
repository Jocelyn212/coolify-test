---
---

<div class="flex flex-col gap-6">
  
  <!-- Header -->
  <div class="mb-6">
    <h2 class="text-3xl font-extrabold tracking-tight mb-2 bg-gradient-to-r from-text-light to-accent-mint bg-clip-text text-transparent">Generador de Emails</h2>
    <p class="mono text-sm text-text-secondary">Crea emails profesionales adaptados a tu necesidad.</p>
  </div>

  <!-- Grid -->
  <div class="grid md:grid-cols-2 gap-6">
    
    <!-- Input -->
    <div class="flex flex-col gap-4">
      <div>
        <label class="mono text-xs tracking-widest uppercase font-semibold text-accent-mint">Asunto</label>
        <input
          id="email-asunto"
          type="text"
          placeholder="Ej: Propuesta de colaboración"
          class="w-full mt-2 border-2 border-primary rounded-lg p-3 text-sm focus:outline-none focus:border-accent-mint transition-all bg-primary/30 text-text-light placeholder:text-text-secondary"
        />
      </div>

      <div>
        <label class="mono text-xs tracking-widest uppercase font-semibold text-accent-mint">Tono</label>
        <select
          id="email-tono"
          class="w-full mt-2 border-2 border-primary rounded-lg p-3 text-sm focus:outline-none focus:border-accent-mint transition-all bg-primary/30 text-text-light"
        >
          <option value="formal">Formal y profesional</option>
          <option value="semi-formal">Semi-formal</option>
          <option value="amigable">Amigable pero profesional</option>
        </select>
      </div>

      <div>
        <label class="mono text-xs tracking-widest uppercase font-semibold text-accent-mint">Contenido</label>
        <textarea
          id="email-input"
          placeholder="Describe qué quieres comunicar..."
          class="w-full mt-2 min-h-50 border-2 border-primary rounded-xl p-4 text-sm resize-none focus:outline-none focus:border-accent-mint transition-all bg-primary/30 text-text-light placeholder:text-text-secondary"
        ></textarea>
      </div>

      <button
        id="email-btn"
        class="mono text-sm py-3 px-4 rounded-lg transition-all font-medium text-zinc-950 bg-accent-mint hover:shadow-lg hover:bg-accent-mint/90"
      >
        ✓ Generar Email
      </button>
    </div>

    <!-- Output -->
    <div class="flex flex-col gap-4">
      <div class="flex justify-between items-center">
        <label class="mono text-xs tracking-widest uppercase font-semibold text-accent-mint">Email generado</label>
        <button id="email-copiar" class="mono text-sm transition-all font-medium hidden px-3 py-1 rounded text-text-light bg-accent-mint/15 hover:bg-accent-mint/25 hover:text-accent-mint">
          copiar →
        </button>
      </div>

      <div id="email-output" class="relative min-h-60 border-2 rounded-xl p-4 text-sm leading-relaxed transition-all bg-gradient-to-br from-primary/30 to-bg-dark/80 border-primary text-text-light">
        <span id="email-placeholder" class="text-text-secondary">El email aparecerá aquí...</span>
        <div id="email-loading" class="absolute inset-0 items-center justify-center hidden">
          <div class="flex gap-1">
            <span class="w-3 h-3 rounded-full animate-bounce bg-gradient-primary" style="animation-delay:0s;"></span>
            <span class="w-3 h-3 rounded-full animate-bounce bg-gradient-primary-subtle" style="animation-delay:0.15s;"></span>
            <span class="w-3 h-3 rounded-full animate-bounce bg-accent-mint" style="animation-delay:0.3s;"></span>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div id="email-stats" class="grid grid-cols-2 gap-2 hidden">
        <div class="border-2 border-primary rounded-lg p-4 transition-all bg-primary-dark/30">
          <div id="email-tiempo" class="text-lg font-bold text-accent-mint">—</div>
          <div class="mono text-xs uppercase tracking-widest mt-2 text-text-secondary">segundos</div>
        </div>
        <div class="border-2 border-primary rounded-lg p-4 transition-all bg-primary-dark/30">
          <div id="email-palabras" class="text-lg font-bold text-primary-light">—</div>
          <div class="mono text-xs uppercase tracking-widest mt-2 text-text-secondary">palabras</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('email-btn');
  const asuntoInput = document.getElementById('email-asunto') as HTMLInputElement;
  const tonoSelect = document.getElementById('email-tono') as HTMLSelectElement;
  const input = document.getElementById('email-input') as HTMLTextAreaElement;
  const output = document.getElementById('email-output')!;
  const loading = document.getElementById('email-loading')!;
  const placeholder = document.getElementById('email-placeholder')!;
  const copiarBtn = document.getElementById('email-copiar')!;
  const stats = document.getElementById('email-stats')!;
  const statTiempo = document.getElementById('email-tiempo')!;
  const statPalabras = document.getElementById('email-palabras')!;

  let resultadoTexto = '';

  btn?.addEventListener('click', async () => {
    const asunto = asuntoInput.value.trim();
    const tono = tonoSelect.value;
    const texto = input.value.trim();
    
    if (!asunto || !texto) return;

    placeholder.classList.add('hidden');
    loading.classList.remove('hidden');
    copiarBtn.classList.add('hidden');
    stats.classList.add('hidden');

    const inicio = Date.now();

    try {
      const res = await fetch('/api/ai', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          texto, 
          accion: 'email',
          metadata: { asunto, tono }
        }),
      });

      const data = await res.json();
      const tiempo = ((Date.now() - inicio) / 1000).toFixed(1);
      const palabras = data.resultado.split(' ').length;

      resultadoTexto = data.resultado;
      loading.classList.add('hidden');

      output.innerHTML = '';
      output.className = 'relative min-h-60 border-2 rounded-xl p-4 text-sm leading-relaxed transition-all bg-gradient-to-br from-primary/30 to-bg-dark/80 border-primary text-text-light whitespace-pre-wrap';
      output.appendChild(document.createTextNode(resultadoTexto));

      copiarBtn.classList.remove('hidden');
      stats.classList.remove('hidden');
      statTiempo.textContent = tiempo + 's';
      statPalabras.textContent = palabras.toString();

    } catch (e) {
      loading.classList.add('hidden');
      output.innerHTML = '<span class="text-red-400 mono text-xs">Error al generar el email. Inténtalo de nuevo.</span>';
    }
  });

  copiarBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(resultadoTexto);
    copiarBtn.textContent = '✓ copiado';
    setTimeout(() => copiarBtn.textContent = 'copiar →', 2000);
  });
</script>
